{
  "name": "sitelink",
  "module": "index.ts",
  "devDependencies": {
    "@effect-native/bun-test": "^0.1.3",
    "@effect/language-service": "^0.63.2",
    "@types/bun": "latest",
    "concurrently": "^9.1.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.36.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.2"
  },
  "private": true,
  "scripts": {
    "prepare": "effect-language-service patch",
    "typecheck": "tsc --build --noEmit",
    "format": "oxfmt --write .",
    "check-format": "oxfmt --check .",
    "lint": "oxlint",
    "dev:all": "concurrently \"bun --cwd apps/backend dev\" \"bun --cwd apps/mobile dev\"",
    "callout:detect": "python3 packages/callout-processor/src/detect.py"
  },
  "type": "module",
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*"
    ],
    "catalogs": {
      "effect": {
        "effect": "3.19.14",
        "@effect/experimental": "0.46.4",
        "@effect/platform": "0.94.1"
      },
      "livestore": {
        "@livestore/livestore": "0.4.0-dev.22",
        "@livestore/adapter-expo": "0.4.0-dev.22",
        "@livestore/adapter-web": "0.4.0-dev.22",
        "@livestore/adapter-cloudflare": "0.4.0-dev.22",
        "@livestore/devtools-expo": "0.4.0-dev.22",
        "@livestore/react": "0.4.0-dev.22",
        "@livestore/sync-cf": "0.4.0-dev.22",
        "@livestore/peer-deps": "0.4.0-dev.22"
      },
      "better-auth": {
        "better-auth": "^1.1.15"
      }
    }
  }
}
